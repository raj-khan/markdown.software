# ---------------------------------------------------------------------------
# markdowntopdf.sh environment variables
# Copy this file to `.env.local` and fill in what you need.
# Everything here is OPTIONAL — the editor + PDF export work with no config.
# ---------------------------------------------------------------------------

# Local development only: path to a system Chrome/Chromium used to render PDFs.
# Leave unset on Vercel/serverless (the bundled @sparticuz/chromium is used).
# Common values:
#   Linux : /usr/bin/google-chrome
#   macOS : /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# CHROME_PATH=/usr/bin/google-chrome

# Optional: Supabase (accounts + saved documents). Without these, the app
# runs as a fully local, no-login tool.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
